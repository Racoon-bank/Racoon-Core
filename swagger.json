            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "MoneyOperationDto": {
        "type": "object",
        "properties": {
          "amount": {
            "minimum": 0.01,
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "OperationType": {
